# .env.example
#
# Variaveis de ambiente do backend.
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env — apenas o .env.example.
#
# Todas as variaveis marcadas com [OBRIGATORIO] causam falha imediata
# da aplicacao se estiverem ausentes ou invalidas (fail-fast em env.js).

# ─── Aplicacao ────────────────────────────────────────────────────────────────

NODE_ENV=development
# Valores: development | production | test

PORT=3000

APP_NAME=app
APP_VERSION=1.0.0

# ─── Banco de dados ───────────────────────────────────────────────────────────

# [OBRIGATORIO] Deve comecar com postgresql:// ou postgres://
DATABASE_URL=postgresql://usuario:senha@localhost:5432/nome_do_banco

# ─── JWT ─────────────────────────────────────────────────────────────────────

# [OBRIGATORIO] Minimo 64 caracteres.
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

# Tempo de expiracao do access token (formato ms ou string: 30m, 1h, 7d)
JWT_EXPIRES_IN=30m

# Tempo de expiracao do refresh token
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────

# [OBRIGATORIO em producao] Lista de origens separadas por virgula.
# Nunca usar * em APIs autenticadas.
# Exemplo: https://app.dominio.com,https://admin.dominio.com
CORS_ORIGINS=http://localhost:5173

# ─── Rate limiting ────────────────────────────────────────────────────────────

# Maximo de requisicoes por janela de tempo
RATE_LIMIT_MAX=100

# Janela em milissegundos (60000 = 1 minuto)
RATE_LIMIT_WINDOW_MS=60000

# ─── Variaveis opcionais por projeto ─────────────────────────────────────────
# Descomentar e preencher conforme necessidade do projeto

# Criptografia de certificados A1 (CTe/NFe) — minimo 32 caracteres
# CERT_ENCRYPTION_KEY=

# SEFAZ
# SEFAZ_AMBIENTE=homologacao
# Valores: homologacao | producao

# SMTP para envio de emails
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@dominio.com
